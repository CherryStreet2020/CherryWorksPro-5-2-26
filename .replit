modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["zip", "glib", "nss", "nspr", "atk", "at-spi2-atk", "cups", "dbus", "expat", "libdrm", "pango", "cairo", "alsa-lib", "mesa", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb", "xorg.libxshmfence", "gtk3", "libxkbcommon"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5099
externalPort = 3000

[[ports]]
localPort = 5100
externalPort = 3001

[[ports]]
localPort = 5101
externalPort = 3002

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EMAIL_CAPTURE_DIR=/tmp/cherry-e2e-emails MARKETING_OS_ENABLED=true VITE_MARKETING_OS_ENABLED=true EMAIL_OAUTH_ENABLED=true VITE_EMAIL_OAUTH_ENABLED=true npm run dev"
waitForPort = 5000

[userenv]

[userenv.development]

[userenv.shared]
# Encryption keys (BANKING_ENCRYPTION_KEY, SMTP_ENCRYPTION_KEY) live in Replit Secrets (encrypted store), NOT here. Never commit secrets to .replit.

[userenv.production]
SKIP_MIGRATION_REPLAY_CHECK = "1"
SKIP_STARTUP_MIGRATIONS = "1"
MARKETING_OS_ENABLED = "true"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[agent]
integrations = ["javascript_object_storage:2.0.0"]
