  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "prestart": "npm run db:migrate:prod",
    "start": "NODE_ENV=production node dist/index.cjs",
    "db:migrate:prod": "tsx server/migrate-production.ts && drizzle-kit push --force",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit",
    "lint": "npx eslint . --max-warnings 0",
    "test": "vitest run --reporter=verbose",
    "test:e2e": "playwright test --reporter=line",
    "proof:bundle:strict": "node scripts/proof/bundle_strict.mjs",
    "test:e2e:dashboard": "playwright test e2e/dashboard-kpi.spec.ts --reporter=line"
  },
