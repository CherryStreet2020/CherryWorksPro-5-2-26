# Ignore everything under /proof/ except the explicitly tracked sub-bundles
# below — git cannot re-include children of an ignored directory, so we have
# to ignore /proof/* (contents) instead of /proof/ (directory).
/proof/*
# Sprint 2n.1 brand-modal proof bundle (Task #361) — explicitly track the
# eight authenticated screenshots + the status report, since they're the
# deliverable referenced from the sprint write-up.
!/proof/2n1/
/proof/2n1/*
!/proof/2n1/STATUS.md
!/proof/2n1/brand-modal-light-1280.jpg
!/proof/2n1/brand-modal-light-1366.jpg
!/proof/2n1/brand-modal-light-1440.jpg
!/proof/2n1/brand-modal-light-1920.jpg
!/proof/2n1/brand-modal-dark-1280.jpg
!/proof/2n1/brand-modal-dark-1366.jpg
!/proof/2n1/brand-modal-dark-1440.jpg
!/proof/2n1/brand-modal-dark-1920.jpg
!/proof/2n1/settings-brands-after.jpg

# Sprint M-Chat-1 marketing-chatbot proof bundle (Task #406) — track the
# HR4 sweep, schema-parity dump, and full vitest log so the deliverable
# is reproducible from a fresh checkout.
!/proof/mchat1/
/proof/mchat1/*
!/proof/mchat1/mchat1-hr4-sweep.txt
!/proof/mchat1/mchat1-schema-parity.txt
!/proof/mchat1/mchat1-vitest.txt
!/proof/mchat1/mchat1-tsc.txt
!/proof/mchat1/STATUS.md
