# Runtime data — receipts uploaded by users at runtime should never be
# committed (real customer data). Folder is created on demand by the app.
uploads/

# Runtime export bundles produced on demand (zips of reports/codebases).
# Some files have no extension so we exclude the whole directory.
exports/

